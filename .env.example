# Required - your OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# Optional — override default models
# CLASSIFIER_MODEL=gpt-4o-mini
# GENERATOR_MODEL=gpt-4o-mini

# Optional — confidence threshold (default 0.7)
# CONFIDENCE_THRESHOLD=0.7

# Optional — log file path (default route_log.jsonl)
# LOG_FILE=route_log.jsonl
# For docker-compose volume logging, you can use:
# LOG_FILE=/app/logs/route_log.jsonl

# Optional — CORS origins for web frontends (comma-separated)
# Include your GitHub Pages URL if hosting frontend there
# ALLOWED_ORIGINS=http://localhost:8000,https://ramalokeshreddyp.github.io
